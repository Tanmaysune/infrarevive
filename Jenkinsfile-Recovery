pipeline {
    agent any

    environment {
        KUBECONFIG_PATH   = "/home/ec2-user/.kube/config"
        NAMESPACE         = "infrarevive"
        ANSIBLE_INVENTORY = "${WORKSPACE}/ansible/inventory.ini"
        TERRAFORM_DIR     = "${WORKSPACE}/terraform"
        SSH_KEY           = "/home/ec2-user/.ssh/infrarevive-key.pem"
        MASTER_IP         = "MASTER_IP_PLACEHOLDER"
    }

    stages {

        stage('Identify Failed Node') {
            steps {
                echo "=== RECOVERY PIPELINE TRIGGERED BY ALERTMANAGER ==="
                echo "Checking current cluster state..."
                sh """
                    export KUBECONFIG=${KUBECONFIG_PATH}
                    echo "--- Node Status ---"
                    kubectl get nodes -o wide
                    echo "--- Pod Status ---"
                    kubectl get pods -n ${NAMESPACE} -o wide
                    echo "--- Identifying NotReady nodes ---"
                    kubectl get nodes | grep -E "NotReady|Unknown" || echo "Could not identify specific dead node from kubectl"
                """
            }
        }

        stage('Terraform Init') {
            steps {
                echo "Initializing Terraform..."
                dir("${TERRAFORM_DIR}") {
                    sh "terraform init -reconfigure"
                }
            }
        }

        stage('Identify Dead Worker Index') {
            steps {
                script {
                    echo "Getting dead node info from Terraform state..."
                    dir("${TERRAFORM_DIR}") {
                        def workerIds = sh(
                            script: "terraform output -json worker_instance_ids | tr -d '[]\" ' | tr ',' '\\n'",
                            returnStdout: true
                        ).trim().split('\n')

                        def deadIndex = 2  // Default to worker index 2 for this demo
                        // In production, you would parse the Alertmanager webhook payload
                        // to get the exact instance ID that died
                        env.DEAD_WORKER_INDEX = "${deadIndex}"
                        echo "Dead worker index identified: ${env.DEAD_WORKER_INDEX}"
                    }
                }
            }
        }

        stage('Terraform Destroy Dead Node') {
            steps {
                echo "Destroying dead EC2 node..."
                dir("${TERRAFORM_DIR}") {
                    sh """
                        terraform destroy \
                            -target='aws_instance.k8s_workers[${env.DEAD_WORKER_INDEX}]' \
                            -auto-approve
                    """
                }
                echo "Dead node destroyed successfully."
            }
        }

        stage('Terraform Provision New Node') {
            steps {
                echo "Provisioning fresh replacement node..."
                dir("${TERRAFORM_DIR}") {
                    sh "terraform apply -auto-approve"
                }
                echo "New node provisioned. Waiting for it to boot..."

                // Get the new worker IPs
                script {
                    dir("${TERRAFORM_DIR}") {
                        def newWorkerIps = sh(
                            script: "terraform output -json worker_public_ips | tr -d '[]\" ' | tr ',' '\\n'",
                            returnStdout: true
                        ).trim().split('\n')
                        env.NEW_WORKER_IP = newWorkerIps[env.DEAD_WORKER_INDEX.toInteger()].trim()
                        echo "New worker IP: ${env.NEW_WORKER_IP}"
                    }
                }
            }
        }

        stage('Wait for Node Boot') {
            steps {
                echo "Waiting 90 seconds for new EC2 to fully boot and accept SSH..."
                sh "sleep 90"

                echo "Testing SSH connectivity to new node..."
                sh """
                    for i in 1 2 3 4 5; do
                        ssh -o StrictHostKeyChecking=no \
                            -o ConnectTimeout=10 \
                            -i ${SSH_KEY} \
                            ec2-user@${env.NEW_WORKER_IP} 'echo SSH OK' && break || sleep 20
                    done
                """
            }
        }

        stage('Update Ansible Inventory') {
            steps {
                echo "Updating Ansible inventory with new node IP..."
                script {
                    // Read current inventory
                    def inventory = readFile("${WORKSPACE}/ansible/inventory.ini")

                    // Get all current worker IPs from terraform output
                    dir("${TERRAFORM_DIR}") {
                        def newWorkerIpsRaw = sh(
                            script: "terraform output -json worker_public_ips | tr -d '[]\" ' | tr ',' '\\n'",
                            returnStdout: true
                        ).trim().split('\n')

                        def newInventory = """[jenkins]
JENKINS_IP ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/infrarevive-key.pem

[k8s_master]
${env.MASTER_IP} ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/infrarevive-key.pem

[k8s_workers]
${newWorkerIpsRaw[0].trim()} ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/infrarevive-key.pem
${newWorkerIpsRaw[1].trim()} ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/infrarevive-key.pem
${newWorkerIpsRaw[2].trim()} ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/infrarevive-key.pem
"""
                        writeFile(file: "${WORKSPACE}/ansible/inventory.ini", text: newInventory)
                    }
                    echo "Ansible inventory updated with new worker IPs."
                }
            }
        }

        stage('Get Fresh Join Command from Master') {
            steps {
                echo "Generating fresh kubeadm join command from master node..."
                sh """
                    ssh -o StrictHostKeyChecking=no \
                        -i ${SSH_KEY} \
                        ec2-user@${env.MASTER_IP} \
                        'kubeadm token create --print-join-command' > /tmp/kubeadm_join_command.sh
                    chmod +x /tmp/kubeadm_join_command.sh
                    echo "Join command generated:"
                    cat /tmp/kubeadm_join_command.sh
                """
            }
        }

        stage('Ansible Configure New Node') {
            steps {
                echo "Running Ansible to configure new node and join cluster..."
                sh """
                    ansible-playbook \
                        -i ${WORKSPACE}/ansible/inventory.ini \
                        ${WORKSPACE}/ansible/setup.yml \
                        --limit k8s_workers \
                        -e "target_worker=${env.NEW_WORKER_IP}" \
                        --private-key=${SSH_KEY} \
                        -v
                """
                echo "Ansible configuration complete."
            }
        }

        stage('Puppet Enforce State on New Node') {
            steps {
                echo "Running Puppet to enforce desired state on new node..."
                sh """
                    ssh -o StrictHostKeyChecking=no \
                        -i ${SSH_KEY} \
                        ec2-user@${env.NEW_WORKER_IP} \
                        'sudo yum install -y puppet && sudo puppet apply /etc/puppet/manifests/enforce.pp' || true
                """
                echo "Puppet enforcement complete."
            }
        }

        stage('Verify Node Joined Cluster') {
            steps {
                echo "Waiting for node to register in Kubernetes..."
                sh "sleep 30"

                sh """
                    export KUBECONFIG=${KUBECONFIG_PATH}
                    echo "--- Current Node Status ---"
                    kubectl get nodes -o wide

                    echo "--- Waiting for new node to be Ready ---"
                    kubectl wait --for=condition=Ready node --all --timeout=120s || true

                    echo "--- Final Node Status ---"
                    kubectl get nodes -o wide
                """
            }
        }

        stage('Verify Pods Rescheduled') {
            steps {
                echo "Checking if pods have been rescheduled on new node..."
                sh """
                    export KUBECONFIG=${KUBECONFIG_PATH}
                    echo "--- Pod Status ---"
                    kubectl get pods -n ${NAMESPACE} -o wide

                    echo "--- Waiting for all pods to be Running ---"
                    kubectl wait --for=condition=Ready pod --all -n ${NAMESPACE} --timeout=120s || true

                    echo "--- Final Pod Status ---"
                    kubectl get pods -n ${NAMESPACE} -o wide
                    kubectl get services -n ${NAMESPACE}
                """
            }
        }

    }

    post {
        success {
            echo "================================================================"
            echo "=== RECOVERY COMPLETE ==="
            echo "Dead node has been replaced."
            echo "Kubernetes cluster is healthy."
            echo "Application is running."
            echo "MySQL data is intact."
            echo "Total recovery time: check build duration above."
            echo "================================================================"
        }

        failure {
            echo "================================================================"
            echo "=== RECOVERY PIPELINE FAILED ==="
            echo "Manual intervention required."
            echo "Check the logs above for the exact failure point."
            echo "Common fixes:"
            echo "1. Terraform state issue — run terraform init"
            echo "2. SSH key not available on Jenkins — check /home/ec2-user/.ssh/"
            echo "3. Kubeadm join token expired — SSH to master, run: kubeadm token create --print-join-command"
            echo "================================================================"
        }
    }
}
