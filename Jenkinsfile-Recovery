def awsWorkerValue(int index, String attribute) {
    return sh(
        script: """
            aws ec2 describe-instances \\
              --filters 'Name=tag:Name,Values=infrarevive-worker-${index}' \\
              --query 'Reservations[].Instances[] | sort_by(@, &LaunchTime)[-1].${attribute}' \\
              --output text
        """,
        returnStdout: true
    ).trim()
}

def awsInstanceValue(String name, String attribute) {
    return sh(
        script: """
            aws ec2 describe-instances \\
              --filters 'Name=tag:Name,Values=${name}' \\
              --query 'Reservations[].Instances[] | sort_by(@, &LaunchTime)[-1].${attribute}' \\
              --output text
        """,
        returnStdout: true
    ).trim()
}

def requireValue(String label, String value) {
    if (!value || value == 'None') {
        error("Missing ${label} in AWS. Aborting without changing Terraform state.")
    }
    return value
}

pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    environment {
        KUBECONFIG_PATH = '/var/lib/jenkins/.kube/config'
        NAMESPACE       = 'infrarevive'
        TERRAFORM_DIR   = "${WORKSPACE}/terraform"
        SSH_KEY         = '/var/lib/jenkins/.ssh/infrarevive-key.pem'
        JOIN_COMMAND    = "${WORKSPACE}/.kubeadm-join-command"
    }

    stages {
        stage('Identify Failed Node') {
            steps {
                sh '''
                    set -eu
                    export KUBECONFIG="$KUBECONFIG_PATH"
                    kubectl get nodes -o wide
                    kubectl get pods -n "$NAMESPACE" -o wide
                '''
            }
        }

        stage('Terraform Init') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    dir("${TERRAFORM_DIR}") {
                        sh 'aws dynamodb describe-table --table-name infrarevive-terraform-locks >/dev/null'
                        sh 'terraform init -input=false'
                        script {
                            env.WORKER_COUNT = sh(
                                script: "terraform output -json worker_instance_ids | jq 'length'",
                                returnStdout: true
                            ).trim()
                            if (!env.WORKER_COUNT.isInteger() || env.WORKER_COUNT.toInteger() < 1) {
                                error("Invalid worker count in Terraform state: ${env.WORKER_COUNT}")
                            }
                        }
                    }
                }
            }
        }

        stage('Identify Dead Worker') {
            steps {
                script {
                    def deadIndex = -1
                    for (int i = 0; i < env.WORKER_COUNT.toInteger(); i++) {
                        def state = awsWorkerValue(i, 'State.Name')
                        def privateIp = awsWorkerValue(i, 'PrivateIpAddress')
                        def publicIp = awsWorkerValue(i, 'PublicIpAddress')
                        def nodeStatus = ''
                        def nodeName = ''

                        if (privateIp && privateIp != 'None') {
                            def node = sh(
                                script: """
                                    export KUBECONFIG=${KUBECONFIG_PATH}
                                    kubectl get nodes -o wide --no-headers | awk -v ip='${privateIp}' '\$6 == ip { print \$1, \$2 }'
                                """,
                                returnStdout: true
                            ).trim()
                            if (node) {
                                def fields = node.split(/\s+/)
                                nodeName = fields[0]
                                nodeStatus = fields.size() > 1 ? fields[1] : ''
                            }
                        }

                        nodeStatus = nodeStatus ?: 'NotFound'
                        echo "Worker ${i}: EC2=${state ?: 'missing'}, private=${privateIp ?: 'missing'}, public=${publicIp ?: 'missing'}, Kubernetes=${nodeStatus}"

                        if (state != 'running' || nodeStatus != 'Ready') {
                            deadIndex = i
                            env.OLD_NODE_NAME = nodeName
                            break
                        }
                    }

                    if (deadIndex < 0) {
                        error('All workers are running and Ready. No recovery action was taken.')
                    }
                    env.DEAD_WORKER_INDEX = deadIndex.toString()
                    echo "Recovering worker ${env.DEAD_WORKER_INDEX}."
                }
            }
        }

        stage('Replace Dead Worker') {
            steps {
                timeout(time: 12, unit: 'MINUTES') {
                    dir("${TERRAFORM_DIR}") {
                        sh '''
                            set -eu
                            target="aws_instance.k8s_workers[$DEAD_WORKER_INDEX]"
                            terraform apply -target="$target" -replace="$target" -auto-approve -input=false -lock-timeout=2m
                        '''
                    }
                }
                sh '''
                    set -eu
                    if [ -n "${OLD_NODE_NAME:-}" ]; then
                        export KUBECONFIG="$KUBECONFIG_PATH"
                        kubectl delete node "$OLD_NODE_NAME" --ignore-not-found
                    fi
                '''
            }
        }

        stage('Wait for New Worker') {
            steps {
                timeout(time: 6, unit: 'MINUTES') {
                    script {
                        def index = env.DEAD_WORKER_INDEX.toInteger()
                        retry(6) {
                            env.NEW_WORKER_IP = requireValue('new worker public IP', awsWorkerValue(index, 'PublicIpAddress'))
                            env.NEW_WORKER_INSTANCE_ID = requireValue('new worker instance ID', awsWorkerValue(index, 'InstanceId'))
                            sleep time: 5, unit: 'SECONDS'
                        }
                    }
                    sh '''
                        set -eu
                        aws ec2 wait instance-status-ok --instance-ids "$NEW_WORKER_INSTANCE_ID"
                        for attempt in $(seq 1 10); do
                            if ssh -o BatchMode=yes -o StrictHostKeyChecking=no -o ConnectTimeout=10 -i "$SSH_KEY" "ec2-user@$NEW_WORKER_IP" 'echo SSH_OK'; then
                                exit 0
                            fi
                            sleep 10
                        done
                        echo "New worker is not reachable by SSH: $NEW_WORKER_IP" >&2
                        exit 1
                    '''
                }
            }
        }

        stage('Configure and Join Worker') {
            steps {
                script {
                    env.MASTER_IP = requireValue('master public IP', awsInstanceValue('infrarevive-master', 'PublicIpAddress'))
                    env.JENKINS_IP = requireValue('Jenkins public IP', awsInstanceValue('infrarevive-jenkins', 'PublicIpAddress'))
                }
                sh '''
                    set -eu
                    ssh -o BatchMode=yes -o StrictHostKeyChecking=no -o ConnectTimeout=10 -i "$SSH_KEY" "ec2-user@$MASTER_IP" \
                      'kubeadm token create --ttl 15m --print-join-command' > "$JOIN_COMMAND"
                    chmod 700 "$JOIN_COMMAND"
                    test -s "$JOIN_COMMAND"
                '''
                script {
                    def workerIps = []
                    for (int i = 0; i < env.WORKER_COUNT.toInteger(); i++) {
                        workerIps.add(requireValue("worker ${i} public IP", awsWorkerValue(i, 'PublicIpAddress')))
                    }
                    writeFile file: "${WORKSPACE}/ansible/inventory.ini", text: """[jenkins]
${env.JENKINS_IP} ansible_user=ec2-user

[k8s_master]
${env.MASTER_IP} ansible_user=ec2-user

[k8s_workers]
${workerIps.collect { "${it} ansible_user=ec2-user" }.join('\n')}
"""
                }
                sh '''
                    set -eu
                    ansible-playbook -i "$WORKSPACE/ansible/inventory.ini" "$WORKSPACE/ansible/setup-workers.yml" \
                      --limit "$NEW_WORKER_IP" --private-key="$SSH_KEY" \
                      -e "join_command_file=$JOIN_COMMAND"
                '''
            }
        }

        stage('Verify Recovery') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    sh '''
                        set -eu
                        export KUBECONFIG="$KUBECONFIG_PATH"
                        for attempt in $(seq 1 24); do
                            status=$(kubectl get nodes -o wide --no-headers | awk -v ip="$NEW_WORKER_IP" '$6 == ip { print $2 }')
                            if [ "$status" = 'Ready' ]; then
                                kubectl get nodes -o wide
                                kubectl wait --for=condition=Ready pod --all -n "$NAMESPACE" --timeout=120s
                                kubectl get pods -n "$NAMESPACE" -o wide
                                exit 0
                            fi
                            sleep 10
                        done
                        echo "Replacement worker did not join as Ready." >&2
                        exit 1
                    '''
                }
            }
        }
    }

    post {
        always {
            sh 'rm -f "$JOIN_COMMAND" || true'
        }
        success {
            echo 'Recovery complete: the failed worker was replaced and verified Ready.'
        }
        failure {
            dir("${TERRAFORM_DIR}") {
                sh 'terraform version || true; pgrep -af terraform || true'
            }
        }
    }
}
